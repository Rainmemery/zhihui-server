<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "http://mybatis.org/dtd/mybatis-3-mapper.dtd">

<mapper namespace="com.zhihui.mapper.MeetingMapper">

    <resultMap id="BaseResultMap" type="com.zhihui.entity.Meeting">
        <id column="id" property="id"/>
        <result column="title" property="title"/>
        <result column="description" property="description"/>
        <result column="start_time" property="startTime"/>
        <result column="end_time" property="endTime"/>
        <result column="status" property="status"/>
        <result column="creator_id" property="creatorId"/>
        <result column="create_time" property="createTime"/>
        <result column="update_time" property="updateTime"/>
    </resultMap>

    <resultMap id="MeetingVOMap" type="com.zhihui.vo.MeetingVO" extends="BaseResultMap">
        <result column="creator_name" property="creatorName"/>
        <collection property="participants"
                    ofType="com.zhihui.vo.ParticipantVO">
            <result column="p_user_id" property="userId"/>
            <result column="p_username" property="username"/>
            <result column="p_role" property="role"/>
        </collection>
    </resultMap>

    <insert id="insert" useGeneratedKeys="true" keyProperty="id">
        INSERT INTO meeting (title, description, start_time, end_time, status, creator_id)
        VALUES (#{title}, #{description}, #{startTime}, #{endTime}, #{status}, #{creatorId})
    </insert>

    <select id="selectById" resultMap="BaseResultMap">
        SELECT * FROM meeting WHERE id = #{id}
    </select>

    <select id="selectList" resultMap="BaseResultMap">
        SELECT * FROM meeting
        <where>
            <if test="query.status != null and query.status != ''">
                AND status = #{query.status}
            </if>
            <if test="query.keyword != null and query.keyword != ''">
                AND title LIKE CONCAT('%', #{query.keyword}, '%')
            </if>
            <if test="query.creatorId != null">
                AND creator_id = #{query.creatorId}
            </if>
            <if test="query.startFrom != null">
                AND start_time >= #{query.startFrom}
            </if>
            <if test="query.startTo != null">
                AND start_time &lt;= #{query.startTo}
            </if>
        </where>
        ORDER BY
        <choose>
            <when test="query.sortBy == 'startTime'">start_time ${query.sortOrder}</when>
            <when test="query.sortBy == 'updateTime'">update_time ${query.sortOrder}</when>
            <otherwise>create_time ${query.sortOrder}</otherwise>
        </choose>
        LIMIT #{offset}, #{size}
    </select>

    <select id="count" resultType="long">
        SELECT COUNT(*) FROM meeting
        <where>
            <if test="query.status != null and query.status != ''">
                AND status = #{query.status}
            </if>
            <if test="query.keyword != null and query.keyword != ''">
                AND title LIKE CONCAT('%', #{query.keyword}, '%')
            </if>
            <if test="query.creatorId != null">
                AND creator_id = #{query.creatorId}
            </if>
            <if test="query.startFrom != null">
                AND start_time >= #{query.startFrom}
            </if>
            <if test="query.startTo != null">
                AND start_time &lt;= #{query.startTo}
            </if>
        </where>
    </select>

    <select id="selectMyCreated" resultMap="BaseResultMap">
        SELECT * FROM meeting
        WHERE creator_id = #{creatorId}
        ORDER BY create_time DESC
        LIMIT #{offset}, #{size}
    </select>

    <select id="selectMyJoined" resultMap="BaseResultMap">
        SELECT m.* FROM meeting m
        INNER JOIN meeting_participant mp ON m.id = mp.meeting_id
        WHERE mp.user_id = #{userId}
        ORDER BY m.create_time DESC
        LIMIT #{offset}, #{size}
    </select>

    <update id="update">
        UPDATE meeting
        SET title = #{title},
        description = #{description},
        start_time = #{startTime},
        end_time = #{endTime},
        status = #{status}
        WHERE id = #{id}
    </update>

    <delete id="deleteById">
        DELETE FROM meeting WHERE id = #{id}
    </delete>

</mapper>