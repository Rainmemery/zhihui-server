<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "http://mybatis.org/dtd/mybatis-3-mapper.dtd">

<mapper namespace="com.zhihui.mapper.MeetingParticipantMapper">

    <resultMap id="BaseResultMap" type="com.zhihui.entity.MeetingParticipant">
        <id column="id" property="id"/>
        <result column="meeting_id" property="meetingId"/>
        <result column="user_id" property="userId"/>
        <result column="role" property="role"/>
        <result column="join_time" property="joinTime"/>
    </resultMap>

    <insert id="insert" useGeneratedKeys="true" keyProperty="id">
        INSERT INTO meeting_participant (meeting_id, user_id, role)
        VALUES (#{meetingId}, #{userId}, #{role})
    </insert>

    <insert id="batchInsert">
        INSERT INTO meeting_participant (meeting_id, user_id, role)
        VALUES
        <foreach collection="participants" item="p" separator=",">
            (#{meetingId}, #{p.userId}, #{p.role})
        </foreach>
    </insert>

    <delete id="deleteById">
        DELETE FROM meeting_participant WHERE id = #{id}
    </delete>

    <delete id="deleteByMeetingAndUser">
        DELETE FROM meeting_participant WHERE meeting_id = #{meetingId} AND user_id = #{userId}
    </delete>

    <select id="selectByMeetingId" resultMap="BaseResultMap">
        SELECT * FROM meeting_participant WHERE meeting_id = #{meetingId}
    </select>

    <select id="selectByMeetingAndUser" resultMap="BaseResultMap">
        SELECT * FROM meeting_participant
        WHERE meeting_id = #{meetingId} AND user_id = #{userId}
    </select>

</mapper>